# ─────────────────────────────────────────────────────────────────────────────
# POE Tools — environment variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Required ────────────────────────────────────────────────────────────────────
# Your Path of Exile session ID.
# How to get it:
#   1. Log in at https://www.pathofexile.com
#   2. Open DevTools (F12) → Application → Cookies → https://www.pathofexile.com
#   3. Copy the value of the "POESESSID" cookie
#
# Note: the session expires when you log out of the website.
POE_SESSID=your_session_id_here
